% Options handling
\SetupKeyvalOptions{family=std, prefix=std@}
\DeclareStringOption[english]{language}
\DeclareStringOption[bachelor]{type}
\ProcessKeyvalOptions*

\newbool{isMaster}
\ifthenelse{\equal{\std@type}{master}}{\setbool{isMaster}{true}}{\setbool{isMaster}{false}}

\DeclareRobustCommand*{\specialization}[1]{\gdef\@specialization{#1}}
\DeclareRobustCommand*{\supervisor}[1]{\gdef\@supervisor{#1}}

