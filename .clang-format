---
# =============================================================================
# .clang-format
# Project-wide coding style configuration for the K-Means Thesis Pipeline.
#
# This file ensures that all C++ and CUDA source files adhere to a consistent 
# professional standard, facilitating easier code reviews and maintaining 
# scientific reproducibility.
# =============================================================================

BasedOnStyle: LLVM

# --- Visual Density & Layout ---
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 120 # Increased limit for modern wide-screen development environments

# --- Structural Rules ---
NamespaceIndentation: None # Flattens hierarchy for better vertical space usage
BreakBeforeBraces: Attach
PointerAlignment: Left    # Modern C++ style: Type* variable
FixNamespaceComments: true # Automatically documents closing namespace braces

# Allow small utility methods to remain on a single line for brevity
AllowShortFunctionsOnASingleLine: Inline

# --- Include Orchestration ---
# Automatically regroups includes into prioritized blocks:
# 1. Main Header
# 2. Standard Library
# 3. External Dependencies (OpenCV, GLFW, CUDA)
# 4. Internal Project Headers
SortIncludes: true
IncludeBlocks: Regroup

IncludeCategories:
  - Regex:           '^<[^/]+>$'
    Priority:        2
  - Regex:           '^<.*>'
    Priority:        3
  - Regex:           '^".*"'
    Priority:        4

# --- Syntactic Spacing ---
SpaceBeforeAssignmentOperators: true
SpaceBeforeParens: ControlStatements
...
