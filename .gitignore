# =============================================================================
# .gitignore
# Version control exclusion rules for the K-Means Thesis Pipeline.
#
# This file prevents build artifacts, local configuration, and temporary 
# session data from cluttering the repository, ensuring a clean and reproducible 
# codebase for the final thesis submission.
# =============================================================================

# --- Project Specific ---
/out/
/build/
/bin/
/obj/
/log/
/logs/
/src/vendor/
assets/icon.ico # Keep original source, but ignore local caches

# --- C++/CUDA Build Artifacts ---
*.o
*.obj
*.slo
*.lo
*.gch
*.pch
*.ilk
*.pdb
*.so
*.dylib
*.dll
*.lai
*.la
*.a
*.lib
*.exe
*.out
*.app
*.d
*.hint

# --- IDE: Visual Studio ---
.vs/
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.VC.db
ipch/
[Dd]ebug/
[Rr]elease/
x64/
x86/

# --- IDE: Visual Studio Code ---
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# --- Global / OS Specific ---
.DS_Store
Thumbs.db
desktop.ini
~$*
*~
*.tmp