@article{davies1979cluster,
  author     = {Davies, David L. and Bouldin, Donald W.},
  title      = {A Cluster Separation Measure},
  year       = {1979},
  issue_date = {February 1979},
  publisher  = {IEEE Computer Society},
  address    = {USA},
